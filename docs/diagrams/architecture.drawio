        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="rag-title" value="&lt;b&gt;RAG KNOWLEDGE ARCHITECTURE&lt;/b&gt;&lt;br&gt;How the System Learns and Retrieves Information" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="477" y="15" width="700" height="55" as="geometry"/>
