        <mxCell id="rag-embed" value="&lt;b&gt;Qwen 9B Embedding&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;host.docker.internal:8002&lt;br&gt;Batch size: 32 | Dense vectors&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=2;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p2">
