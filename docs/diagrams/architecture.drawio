        <mxCell id="md-rejected-arch" value="&lt;font color=&quot;#D32F2F&quot;&gt;✗&lt;/font&gt; Rejected → Archive&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;(logged, NOT synced)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#D32F2F;fontFamily=Helvetica;fontSize=9;dashed=1;" vertex="1" parent="lane7">
          <mxGeometry x="940" y="55" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- CROSS-LANE ARROWS (connecting lanes together)                 -->
        <!-- ============================================================ -->

        <!-- Entry → CAC (vertical from channel router to CAC lane) -->
        <!-- Entry → HR (vertical from channel router to HR lane) -->
        <!-- These are implied by the swim lane layout and the route labels -->

        <!-- CAC Stage → Approval (vertical) -->
        <mxCell id="md-cross-cac-appr" value="proposal (dept=cac)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#5E35B1;dashed=1;fontSize=9;fontFamily=Helvetica;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1260" y="500" as="sourcePoint"/>
            <mxPoint x="1260" y="940" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1260" y="770"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- HR Stage → Approval (vertical) -->
        <mxCell id="md-cross-hr-appr" value="proposal (dept=hr)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1565C0;dashed=1;fontSize=9;fontFamily=Helvetica;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1300" y="710" as="sourcePoint"/>
            <mxPoint x="1300" y="940" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1300" y="770"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Approval → Output (vertical) -->
        <mxCell id="md-cross-appr-out" value="approved → sync" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#388E3C;fontSize=9;fontFamily=Helvetica;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="920" y="1110" as="sourcePoint"/>
            <mxPoint x="920" y="1120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Escalation arrows (CAC → Shared) -->
        <mxCell id="md-cross-cac-esc" value="⚠️ escalation" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#D32F2F;dashed=1;fontSize=9;fontFamily=Helvetica;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="835" y="450" as="sourcePoint"/>
            <mxPoint x="1160" y="820" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="835" y="770"/>
              <mxPoint x="1160" y="770"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Escalation arrows (HR → Shared) -->
        <mxCell id="md-cross-hr-esc" value="⚠️ escalation" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#D32F2F;dashed=1;fontSize=9;fontFamily=Helvetica;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="835" y="660" as="sourcePoint"/>
            <mxPoint x="1160" y="820" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="835" y="770"/>
              <mxPoint x="1160" y="770"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- LEGEND                                                        -->
        <!-- ============================================================ -->
        <mxCell id="md-legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#388E3C&quot;&gt;■&lt;/font&gt; Entry/Output &amp;nbsp; &lt;font color=&quot;#5E35B1&quot;&gt;■&lt;/font&gt; CAC Dept &amp;nbsp; &lt;font color=&quot;#1565C0&quot;&gt;■&lt;/font&gt; HR Dept &amp;nbsp; &lt;font color=&quot;#37474F&quot;&gt;■&lt;/font&gt; Future (dashed) &amp;nbsp; &lt;font color=&quot;#7B1FA2&quot;&gt;■&lt;/font&gt; Shared Services &amp;nbsp; &lt;font color=&quot;#D32F2F&quot;&gt;■&lt;/font&gt; Approval Gate &amp;nbsp; &lt;font color=&quot;#C62828&quot;&gt;◆&lt;/font&gt; LLM Call &amp;nbsp; &lt;font color=&quot;#E65100&quot;&gt;◇&lt;/font&gt; Decision Diamond" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;strokeWidth=1;fontSize=10;fontFamily=Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="1290" width="1100" height="45" as="geometry"/>
        </mxCell>

        <!-- Key insight callout -->
        <mxCell id="md-insight" value="&lt;b&gt;Department Isolation:&lt;/b&gt; Each department has its own orchestrator, agents, Qdrant collections, Excel files, and HOD approver.&lt;br&gt;Paperclip enforces boundaries at 4 layers: DB (dept column), API (JWT RBAC), data zones (per-dept mounts), and event routing." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5E35B1;strokeWidth=2;fontSize=10;fontFamily=Helvetica;align=left;spacingLeft=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1345" width="800" height="45" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
