        </mxCell>
        <mxCell id="mf-s2" value="&lt;b&gt;Slack Bot&lt;/b&gt; (:3003) acknowledges &lt; 100ms, creates background task" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;fontFamily=Helvetica;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="110" y="145" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="mf-3" value="&lt;b&gt;3&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#5E35B1;strokeColor=#5E35B1;fontColor=#FFFFFF;fontSize=12;fontFamily=Helvetica;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="35" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="mf-s3" value="&lt;b&gt;CAC Orchestrator&lt;/b&gt; (:3001) receives POST /query — starts LangGraph pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#5E35B1;strokeWidth=2;fontFamily=Helvetica;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="110" y="205" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="mf-4" value="&lt;b&gt;4&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#5E35B1;strokeColor=#5E35B1;fontColor=#FFFFFF;fontSize=12;fontFamily=Helvetica;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="35" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="mf-s4" value="&lt;b&gt;Classify Intent&lt;/b&gt; — Qwen 122B determines: liquidity / capital / ALM / funding / general" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=2;fontFamily=Helvetica;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="110" y="265" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="mf-5" value="&lt;b&gt;5&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#5E35B1;strokeColor=#5E35B1;fontColor=#FFFFFF;fontSize=12;fontFamily=Helvetica;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="35" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="mf-s5" value="&lt;b&gt;Retrieve Context&lt;/b&gt; — Search Qdrant: cac_docs + cac_chat + cac_knowledge (top-8, min 0.70)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;fontFamily=Helvetica;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="110" y="325" width="500" height="40" as="geometry"/>
