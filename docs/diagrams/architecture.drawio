          <mxGeometry x="420" y="90" width="340" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="rag-chunker" value="&lt;b&gt;Document Chunker&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;512 tokens per chunk&lt;br&gt;128 token overlap&lt;br&gt;PDF / DOCX / XLSX / MD handlers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#5E35B1;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p2">
          <mxGeometry x="20" y="35" width="300" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="rag-indexer" value="&lt;b&gt;Chat Indexer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;SHA-256 deduplication&lt;br&gt;Metadata: user, channel, timestamp&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#5E35B1;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p2">
          <mxGeometry x="20" y="110" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="rag-watcher" value="&lt;b&gt;VaultWatcher&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;60s debounce, path-based routing&lt;br&gt;11 paths: shared + CAC + HR → collections&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#5E35B1;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p2">
          <mxGeometry x="20" y="175" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="rag-compiler" value="&lt;b&gt;Wiki Compiler&lt;/b&gt; (:3007)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;LLM summarization → articles&lt;br&gt;Types: concept, decision, meeting-note,&lt;br&gt;entity, escalation, source-summary&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#5E35B1;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p2">
          <mxGeometry x="20" y="240" width="300" height="70" as="geometry"/>
