          <mxGeometry x="40" y="90" width="300" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="rag-slack" value="💬 &lt;b&gt;Slack Messages&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;#cac-committee, #hr-committee&lt;br&gt;Committee discussions, decisions&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p1">
          <mxGeometry x="20" y="35" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="rag-docs" value="📄 &lt;b&gt;Uploaded Documents&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;PDFs, DOCX, XLSX via Slack&lt;br&gt;Policies, reports, trackers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p1">
          <mxGeometry x="20" y="100" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="rag-vault" value="📓 &lt;b&gt;Obsidian Vault&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Skills, meeting notes, decisions&lt;br&gt;Watched by VaultWatcher (60s)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p1">
          <mxGeometry x="20" y="165" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="rag-proposals" value="✅ &lt;b&gt;Approved Proposals&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Decisions compiled into&lt;br&gt;knowledge articles by Wiki Compiler&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#5E35B1;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p1">
          <mxGeometry x="20" y="230" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="rag-mirror" value="📊 &lt;b&gt;Mirror Data&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;/data/mirror/ (read-only)&lt;br&gt;Corporate Excel trackers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="rag-p1">
          <mxGeometry x="20" y="295" width="260" height="55" as="geometry"/>
