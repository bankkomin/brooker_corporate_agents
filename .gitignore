# Agent runtime memory — reflection-engine rewrites these nightly.
# soul.md is the seed (committed); memory.md/user.md/history are runtime state.
obsidian-vault/*/_memory/*/memory.md
obsidian-vault/*/_memory/*/user.md
obsidian-vault/*/_memory/*/history/

# ============================================================================
# STRICT SECURITY HARDENING  (deny-by-default for secrets & corporate data)
# ============================================================================

# --- Secrets, credentials & private keys --------------------------------
# Every .env variant is ignored; only documented examples may be committed.
.env.*
!.env.example
!.env.sample
!.env.template
*.env
# Private keys / certs / keystores (any extension, anywhere)
*.pem
*.key
*.keystore
*.jks
*.pkcs12
*.pfx
*.p12
*.cer
*.crt
*.der
*.csr
*.asc
*.gpg
*.pgp
# SSH / known credential filenames
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.ppk
.ssh/
.netrc
.npmrc
.pypirc
.htpasswd
# Cloud / service-account credential files
credentials.json
client_secret*.json
service-account*.json
service_account*.json
*-credentials.json
gha-creds-*.json
.aws/
.azure/
.gcloud/
gcloud-*.json
*.kubeconfig
kubeconfig
# Generic token/secret dumps
*.token
*token.json
secrets.*
*.secret
*.secrets
# Whole secrets/ dir — only the placeholder survives (see secrets/.gitignore)
secrets/*
!secrets/.gitkeep

# --- Corporate data zones (PRD data-safety rule: NEVER commit) -----------
/data/
mirror_data/
staging_data/
archive_data/
# Per-service runtime data dir (rag-ingestion's local vector store).
# NOTE: scoped to this path on purpose — a broad services/**/data/ would
# wrongly catch source routes like approval-ui's src/app/[dept]/data/.
services/rag-ingestion/data/
# Vector stores / embeddings (corporate documents live here)
**/qdrant_local/
**/qdrant_storage/
qdrant_data/
chroma_data/
*.sqlite
*.sqlite3
*.duckdb
# Object / DB stores & dumps
minio_data/
postgres_data/
pgdata/
*.dump
*.sql.gz
*.bak
*.backup
*.old
*.orig
*.rej

# --- Worktrees / clones / scratch ---------------------------------------
.clone/
.claude/worktrees/
*.tmp
*.temp
core
core.*
*.stackdump
*.pid

# --- Confidential corporate corpus (transfer via scp, never via git) -----
# The Obsidian vault IS the corporate knowledge base: real BTC holdings,
# loan terms (PN.35 USD 39.02M), board minutes, IC decisions, custodial
# arrangements, director identities. Treat as production data — distribute
# out-of-band (scp / rsync / encrypted bundle), not via this repo.
obsidian-vault/

# --- Office reference files containing REAL portfolio / financial data ---
# IC-dashboard-reference.xlsx has live Feb 2026 positions with MTM, share
# counts, gain/loss percentages. CAC reference docs likely similar.
# Sanitised placeholder-only templates under config/templates/office/ stay
# tracked (they have no real data).
config/templates/cac/CAC_Monthly_CFO_Report.docx
config/templates/cac/CAC_Monthly_Data_Pack.xlsx
config/templates/ic/IC-dashboard-reference.xlsx
config/templates/ic/IC-meeting-deck-reference.pptx
config/templates/ic/IC-meeting-minutes-reference.docx

# --- DB migration with PII seed (real employee emails) -------------------
# 008_agent_access.sql contains hardcoded INSERT VALUES with real emails.
# Schema migration still needed in production — replace with a non-tracked
# seed script or env-driven loader before re-enabling git tracking.
migrations/008_agent_access.sql

# --- Per-agent session memory (may reference internal architecture) ------
.claude/agent-memory/
