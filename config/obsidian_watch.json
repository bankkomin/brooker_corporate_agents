    {"path": "hr/entities/",                 "collection": "hr_knowledge",    "doc_type": "entity"},
    {"path": "risk/concepts/",               "collection": "risk_knowledge",  "doc_type": "concept"},
    {"path": "risk/decisions/",              "collection": "risk_knowledge",  "doc_type": "decision_log"},
    {"path": "risk/meeting-notes/",          "collection": "risk_knowledge",  "doc_type": "meeting_note"},
    {"path": "risk/entities/",               "collection": "risk_knowledge",  "doc_type": "entity"},
    {"path": "legal/concepts/",              "collection": "legal_knowledge", "doc_type": "concept"},
    {"path": "legal/decisions/",             "collection": "legal_knowledge", "doc_type": "decision_log"},
    {"path": "legal/meeting-notes/",         "collection": "legal_knowledge", "doc_type": "meeting_note"},
    {"path": "legal/entities/",              "collection": "legal_knowledge", "doc_type": "entity"},
    {"path": "invest/concepts/",             "collection": "invest_knowledge","doc_type": "concept"},
    {"path": "invest/decisions/",            "collection": "invest_knowledge","doc_type": "decision_log"},
    {"path": "invest/meeting-notes/",        "collection": "invest_knowledge","doc_type": "meeting_note"},
    {"path": "invest/entities/",             "collection": "invest_knowledge","doc_type": "entity"},
    {"path": "ops/concepts/",                "collection": "ops_knowledge",   "doc_type": "concept"},
    {"path": "ops/decisions/",              "collection": "ops_knowledge",   "doc_type": "decision_log"},
    {"path": "ops/meeting-notes/",           "collection": "ops_knowledge",   "doc_type": "meeting_note"},
    {"path": "ops/entities/",               "collection": "ops_knowledge",   "doc_type": "entity"},
    {"path": "it/concepts/",                 "collection": "it_knowledge",    "doc_type": "concept"},
